{
  "name": "health-link",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "homepage": "https://github.com/chriswz1998/finalterm.git",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"vite --port=3000 --host=0.0.0.0\" \"tsx server/index.ts\"",
    "dev:web": "vite --port=3000 --host=0.0.0.0",
    "dev:api": "tsx server/index.ts",
    "build": "vite build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "check:setup": "node scripts/check-setup.mjs",
    "export:kb": "tsx scripts/export-knowledge-shared.ts",
    "capture:screenshots": "node scripts/capture-demo-screenshots.mjs",
    "pack:handoff": "node scripts/pack-handoff.mjs",
    "pack:handoff:full": "node scripts/pack-handoff.mjs --full",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdfjs-dist": "^5.4.54",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.6.3",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "esbuild": "^0.25.0",
    "gh-pages": "^6.3.0",
    "playwright": "^1.49.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.22.4",
    "typescript": "~5.8.2",
    "vitest": "^3.2.4"
  }
}
