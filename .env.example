# LLM（② 标准化 / ③ RAG / ④ 摘要 / 健康问答）— 百炼 / 混元 / Gemini
# LLM_PROVIDER: auto | dashscope | hunyuan | gemini
LLM_PROVIDER=auto

# --- 阿里云百炼 / 通义千问 ---
# 控制台: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY="sk-your-dashscope-key"
DASHSCOPE_CHAT_MODEL=qwen-plus
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_VISION_MODEL=qwen-vl-plus

# --- 腾讯混元 TokenHub ---
HUNYUAN_API_KEY=sk-你的TokenHub密钥
HUNYUAN_MODEL=hy3-preview
HUNYUAN_BASE_URL=https://tokenhub.tencentmaas.com/v1

# --- Google Gemini（可选）---
GEMINI_API_KEY="your-gemini-key"
GEMINI_MODEL=gemini-2.0-flash

# --- 办公小浣熊 OpenClaw Office API（多份报告标准化后：跨报告分析 / 图表 / PPT）---
# 密钥：OpenClaw / 办公小浣熊后台复制的 JWT（15 天试用）
RACCOON_API_HOST=https://xiaohuanxiong.com
RACCOON_API_TOKEN=你的OpenClaw_JWT
ENABLE_RACCOON_ANALYSIS=true

PORT=3001
RAG_ENABLED=true
RAG_MAX_CHUNKS=8

# --- 健康解读 Agent (/agent) 与主应用共用 LLM 配置 ---
# 检查: npm run dev 后执行 npm run check:setup

# --- 微信小程序（个人主体）---
WECHAT_APPID=wx你的AppID
WECHAT_APPSECRET=你的AppSecret
WECHAT_JWT_SECRET=请填随机32位以上字符串
